---
import DefaultLayout from '../layouts/DefaultLayout.astro';
import { Card } from 'accessible-astro-components';
import { Icon } from 'astro-icon/components';
// src/assets/profile_falcon.png 이미지를 import합니다.
import profileFalcon from '../assets/profile_falcon.png';
import { Image } from 'astro:assets'; // astro:assets의 Image 컴포넌트를 사용합니다.
---

<DefaultLayout title="개발 중 - FinalNeoDev" hideFooter={true}>
  <section class="my-32">
    <div class="container">
      <div class="flex flex-col items-center justify-center text-center gap-8">
        <div class="w-64 h-64 md:w-80 md:h-80 rounded-full overflow-hidden shadow-xl mb-6 border-4 border-white dark:border-gray-800">
          <Image src={profileFalcon} alt="A watercolor portrait of a peregrine falcon, representing FinalNeoDev" class="object-cover w-full h-full" />
        </div>
        
        <h1 class="text-4xl font-bold md:text-6xl tracking-tight">
          FinalNeoDev <span class="text-gradient">개발 중</span>
        </h1>
        
        <p class="text-xl text-gray-6xl max-w-md my-4">
          개발, 테스트, 서비스의 모든 과정을 체계적으로 기록하기 위해 이 공간을 열심히 개발하고 있습니다. 곧 멋진 모습으로 찾아뵙겠습니다!
        </p>

        <div class="w-full max-w-md text-left mt-6">
          <Card
            url="https://github.com/finalneodev"
            title="GitHub 저장소 방문하기 🚀"
            class="no-image"
          >
            <p class="text-gray-600 dark:text-gray-400">
              대신 깃허브에서 진행 중인 프로젝트와 README를 먼저 확인하실 수 있습니다.
            </p>
          </Card>
        </div>
        
        <div class="w-full max-w-4xl text-left mt-16 pb-16 border-b border-gray-100 dark:border-gray-800">
          <h2 class="text-3xl font-bold mb-8 text-center" id="portfolio">Portfolio</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <Card
              url="https://finalneodev.github.io/Korea_Holidays/"
              title="Korea Holidays"
              class="no-image"
            >
              <p class="text-gray-600 dark:text-gray-400">
                한국의 공휴일 및 기념일 정보를 제공하는 웹 서비스입니다.
              </p>
            </Card>
            <Card
              url="https://finalneodev.github.io/Korea_Holidays/overtime.html"
              title="Korea OT"
              class="no-image"
            >
              <p class="text-gray-600 dark:text-gray-400">
                초과 근무 및 수당 계산 기능을 제공하는 페이지입니다.
              </p>
            </Card>
            <Card
              url="https://finalneodev.github.io/KERIS_OFL_fonts/"
              title="Korea Font"
              class="no-image"
            >
              <p class="text-gray-600 dark:text-gray-400">
                KERIS 안심 글꼴(OFL) 정보를 제공하고 미리보기 기능을 지원합니다.
              </p>
            </Card>
          </div>
        </div>

        <!-- Latest Blog Posts Section -->
        <div class="w-full max-w-4xl text-left mt-16 pb-16 border-b border-gray-100 dark:border-gray-800">
          <h2 class="text-3xl font-bold mb-8 text-center">Latest Blog Posts</h2>
          
          <!-- 로딩 스켈레톤 -->
          <div id="blog-loading" class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {[1, 2].map(() => (
              <div class="p-6 bg-white dark:bg-gray-900 border border-gray-100 dark:border-gray-800 rounded-2xl animate-pulse space-y-4 shadow-sm">
                <div class="h-4 bg-gray-200 dark:bg-gray-800 rounded w-1/4"></div>
                <div class="h-6 bg-gray-200 dark:bg-gray-800 rounded w-3/4"></div>
                <div class="h-4 bg-gray-200 dark:bg-gray-800 rounded w-16"></div>
              </div>
            ))}
          </div>

          <!-- 빈 상태 -->
          <div id="blog-empty" class="hidden text-center py-12 bg-gray-50 dark:bg-gray-900/50 rounded-2xl border border-dashed border-gray-200 dark:border-gray-800">
            <p class="text-gray-500 dark:text-gray-400">등록된 블로그 글이 없습니다.</p>
          </div>

          <!-- 블로그 컨테이너 -->
          <div id="blog-container" class="grid grid-cols-1 md:grid-cols-2 gap-6 hidden"></div>

          <!-- 더보기 버튼 -->
          <div class="flex justify-center mt-10">
            <a 
              href="/blog" 
              class="px-6 py-3 bg-purple-600 hover:bg-purple-700 text-white font-medium rounded-xl shadow hover:shadow-lg transition duration-200 inline-flex items-center gap-1.5"
            >
              블로그 더보기 <span class="arrow">→</span>
            </a>
          </div>
        </div>

        <!-- Recent Board Messages Section -->
        <div class="w-full max-w-4xl text-left mt-16">
          <h2 class="text-3xl font-bold mb-8 text-center">Recent Board Messages</h2>

          <!-- 로딩 스켈레톤 -->
          <div id="board-loading" class="space-y-4">
            {[1, 2].map(() => (
              <div class="p-6 bg-white dark:bg-gray-900 border border-gray-100 dark:border-gray-800 rounded-2xl animate-pulse space-y-4 shadow-sm">
                <div class="h-6 bg-gray-200 dark:bg-gray-800 rounded w-1/3"></div>
                <div class="h-4 bg-gray-200 dark:bg-gray-800 rounded w-16"></div>
              </div>
            ))}
          </div>

          <!-- 빈 상태 -->
          <div id="board-empty" class="hidden text-center py-12 bg-gray-50 dark:bg-gray-900/50 rounded-2xl border border-dashed border-gray-200 dark:border-gray-800">
            <p class="text-gray-500 dark:text-gray-400">등록된 게시글이 없습니다.</p>
          </div>

          <!-- 게시글 컨테이너 -->
          <div id="board-container" class="space-y-4 hidden"></div>

          <!-- 더보기 버튼 -->
          <div class="flex justify-center mt-10">
            <a 
              href="/board" 
              class="px-6 py-3 border border-purple-600 text-purple-600 dark:text-purple-400 hover:bg-purple-50 dark:hover:bg-purple-950/20 font-medium rounded-xl transition duration-200 inline-flex items-center gap-1.5"
            >
              게시판 더보기 <span class="arrow">→</span>
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- 블로그 포스트 상세 보기 모달 -->
  <div id="blog-modal" class="fixed inset-0 z-50 flex items-center justify-center hidden">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" id="modal-backdrop"></div>
    <div class="relative bg-white dark:bg-gray-950 border border-gray-200 dark:border-gray-800 rounded-2xl w-full max-w-3xl mx-4 shadow-2xl transform transition-all scale-95 duration-200 flex flex-col max-h-[80vh]">
      <div class="p-6 border-b border-gray-100 dark:border-gray-800 flex items-start justify-between gap-4">
        <div>
          <h3 class="text-2xl font-bold text-gray-900 dark:text-gray-100 mb-1" id="modal-title">제목</h3>
          <p class="text-xs text-gray-400 dark:text-gray-500" id="modal-date">작성일</p>
        </div>
        <button id="modal-close-btn" class="p-2 text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-900 rounded-lg transition duration-150">✕</button>
      </div>
      <div class="p-6 md:p-8 overflow-y-auto flex-1 text-gray-800 dark:text-gray-200">
        <article class="markdown-body" id="modal-content"></article>
      </div>
      <div class="p-4 border-t border-gray-100 dark:border-gray-800 bg-gray-50 dark:bg-gray-900/50 flex justify-end rounded-b-2xl">
        <button id="modal-footer-close-btn" class="px-5 py-2.5 bg-purple-600 hover:bg-purple-700 text-white font-medium rounded-xl transition duration-200">닫기</button>
      </div>
    </div>
  </div>
</DefaultLayout>

<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js" defer></script>

<script>
  declare const marked: any;

  document.addEventListener('astro:page-load', () => {
    // API URLs
    const BLOG_API_URL = 'https://fnnas.synology.me:22103/node/api/blog';
    const BOARD_API_URL = 'https://fnnas.synology.me:22103/node/api/posts';

    // State
    let blogPosts = [];
    let boardPosts = [];

    // DOM Elements - Blog
    const blogContainer = document.getElementById('blog-container');
    const blogLoading = document.getElementById('blog-loading');
    const blogEmpty = document.getElementById('blog-empty');

    // DOM Elements - Board
    const boardContainer = document.getElementById('board-container');
    const boardLoading = document.getElementById('board-loading');
    const boardEmpty = document.getElementById('board-empty');

    // Modal DOM Elements
    const blogModal = document.getElementById('blog-modal');
    const modalBackdrop = document.getElementById('modal-backdrop');
    const modalCloseBtn = document.getElementById('modal-close-btn');
    const modalFooterCloseBtn = document.getElementById('modal-footer-close-btn');
    const modalTitle = document.getElementById('modal-title');
    const modalDate = document.getElementById('modal-date');
    const modalContent = document.getElementById('modal-content');

    // Format Date Helper
    const formatDate = (dateString) => {
      if (!dateString) return '';
      try {
        const date = new Date(dateString);
        if (isNaN(date.getTime())) return dateString;
        return date.toLocaleDateString('ko-KR', {
          year: 'numeric',
          month: 'long',
          day: 'numeric'
        });
      } catch (e) {
        return dateString;
      }
    };

    // Helper: Escape HTML
    function escapeHtml(text) {
      if (!text) return '';
      const map = {
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#039;'
      };
      return text.replace(/[&<>"']/g, function(m) { return map[m]; });
    }

    // Modal Control Functions (Blog Detail)
    async function openBlogModal(slug) {
      if (!blogModal || !modalTitle || !modalDate || !modalContent) return;

      blogModal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';

      const post = blogPosts.find(p => p.slug === slug);
      if (!post) return;

      modalTitle.textContent = post.title || '제목 없음';
      modalDate.textContent = `📅 작성일: ${formatDate(post.created_at)}`;

      if (!post.content) {
        modalContent.innerHTML = `<div class="py-12 text-center text-gray-400 dark:text-gray-500 animate-pulse">본문을 불러오는 중...</div>`;
        try {
          const response = await fetch(`${BLOG_API_URL}/${slug}`);
          if (!response.ok) throw new Error();
          const detail = await response.json();
          post.content = detail.content || '본문이 비어있습니다.';
        } catch {
          modalContent.innerHTML = `<div class="py-8 text-center text-red-500 text-sm">본문을 불러올 수 없습니다.</div>`;
          return;
        }
      }

      try {
        modalContent.innerHTML = typeof marked !== 'undefined' ? marked.parse(post.content) : `<pre class="whitespace-pre-wrap">${escapeHtml(post.content)}</pre>`;
      } catch {
        modalContent.innerHTML = `<pre class="whitespace-pre-wrap">${escapeHtml(post.content)}</pre>`;
      }
    }

    function closeBlogModal() {
      if (blogModal) blogModal.classList.add('hidden');
      document.body.style.overflow = '';
    }

    if (modalCloseBtn) modalCloseBtn.addEventListener('click', closeBlogModal);
    if (modalFooterCloseBtn) modalFooterCloseBtn.addEventListener('click', closeBlogModal);
    if (modalBackdrop) modalBackdrop.addEventListener('click', closeBlogModal);
    window.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeBlogModal(); });

    // Toggle Board Detail (Accordion)
    async function toggleBoardDetail(id, articleEl) {
      const contentContainer = articleEl.querySelector('.post-content-container');
      const contentEl = articleEl.querySelector('.post-content-text');
      const toggleArrow = articleEl.querySelector('.toggle-arrow');
      if (!contentContainer || !contentEl) return;

      const isExpanded = !contentContainer.classList.contains('hidden');
      if (isExpanded) {
        contentContainer.classList.add('hidden');
        if (toggleArrow) {
          toggleArrow.style.transform = 'rotate(0deg)';
          toggleArrow.classList.remove('text-purple-600', 'dark:text-purple-400');
        }
        return;
      }

      const post = boardPosts.find(p => p.id.toString() === id.toString());
      if (!post) return;

      if (!post.content) {
        contentEl.innerHTML = `<div class="py-3 text-center text-gray-400 animate-pulse text-sm">본문을 불러오는 중...</div>`;
        contentContainer.classList.remove('hidden');
        if (toggleArrow) {
          toggleArrow.style.transform = 'rotate(90deg)';
          toggleArrow.classList.add('text-purple-600', 'dark:text-purple-400');
        }

        try {
          const response = await fetch(`${BOARD_API_URL}/${id}`);
          if (!response.ok) throw new Error();
          const detail = await response.json();
          post.content = detail.content || '내용이 없습니다.';
        } catch {
          contentEl.innerHTML = `<span class="text-red-500 text-sm">⚠️ 본문을 가져오지 못했습니다.</span>`;
          return;
        }
      }

      contentEl.innerHTML = escapeHtml(post.content);
      contentContainer.classList.remove('hidden');
      if (toggleArrow) {
        toggleArrow.style.transform = 'rotate(90deg)';
        toggleArrow.classList.add('text-purple-600', 'dark:text-purple-400');
      }
    }

    // Fetch and Load Blog (Max 7)
    async function loadBlog() {
      if (!blogContainer || !blogLoading || !blogEmpty) return;
      try {
        const response = await fetch(BLOG_API_URL);
        if (!response.ok) throw new Error();
        const result = await response.json();
        
        if (Array.isArray(result) && result.length > 0) {
          blogPosts = result.sort((a, b) => new Date(b.created_at || 0).getTime() - new Date(a.created_at || 0).getTime());
          const displayPosts = blogPosts.slice(0, 7); // 최대 7개
          
          blogLoading.classList.add('hidden');
          blogContainer.classList.remove('hidden');
          blogContainer.innerHTML = displayPosts.map(post => `
            <article class="p-6 bg-white dark:bg-gray-900 border border-gray-150 dark:border-gray-800 rounded-2xl shadow-sm hover:shadow-md transition-all duration-200 group cursor-pointer flex flex-col justify-between" data-slug="${post.slug}">
              <div class="flex flex-col gap-1.5">
                <span class="text-[10px] font-mono text-purple-500 dark:text-purple-400 font-bold uppercase tracking-wider">${escapeHtml(post.slug)}</span>
                <h3 class="text-lg font-bold text-gray-900 dark:text-gray-100 group-hover:text-purple-600 dark:group-hover:text-purple-400 transition duration-150">${escapeHtml(post.title)}</h3>
              </div>
              <div class="flex items-center justify-between gap-4 mt-6 pt-4 border-t border-gray-100 dark:border-gray-800 text-xs text-gray-400 dark:text-gray-500">
                <span>🕒 ${formatDate(post.created_at)}</span>
                <span class="text-purple-600 dark:text-purple-400 font-semibold inline-flex items-center gap-0.5 group-hover:translate-x-0.5 transition-transform">읽기 →</span>
              </div>
            </article>
          `).join('');
        } else {
          blogLoading.classList.add('hidden');
          blogEmpty.classList.remove('hidden');
        }
      } catch {
        blogLoading.classList.add('hidden');
        blogEmpty.classList.remove('hidden');
      }
    }

    // Fetch and Load Board (Max 7)
    async function loadBoard() {
      if (!boardContainer || !boardLoading || !boardEmpty) return;
      try {
        const response = await fetch(BOARD_API_URL);
        if (!response.ok) throw new Error();
        const result = await response.json();
        
        if (Array.isArray(result) && result.length > 0) {
          boardPosts = result.sort((a, b) => parseInt(b.id) - parseInt(a.id));
          const displayPosts = boardPosts.slice(0, 7); // 최대 7개
          
          boardLoading.classList.add('hidden');
          boardContainer.classList.remove('hidden');
          boardContainer.innerHTML = displayPosts.map(post => `
            <article class="p-5 bg-white dark:bg-gray-900 border border-gray-150 dark:border-gray-800 rounded-2xl shadow-sm hover:shadow-md transition-all duration-200 group cursor-pointer" data-id="${post.id}">
              <div class="flex items-start justify-between gap-4 mb-2">
                <div class="flex items-center gap-2.5">
                  <span class="toggle-arrow text-[10px] text-gray-400 group-hover:text-purple-600 transition-transform duration-200 inline-block">▶</span>
                  <h3 class="text-md font-bold text-gray-900 dark:text-gray-100 group-hover:text-purple-600 dark:group-hover:text-purple-400 transition duration-150">${escapeHtml(post.title)}</h3>
                </div>
                <span class="text-[10px] text-gray-400 font-mono py-0.5 px-1.5 bg-gray-50 dark:bg-gray-950 rounded border border-gray-100 dark:border-gray-900">No. ${post.id}</span>
              </div>
              <div class="flex items-center gap-2 mt-3 text-xs text-gray-400 dark:text-gray-500">
                <span class="font-medium text-gray-600 dark:text-gray-400">${escapeHtml(post.author)}</span>
                <span>•</span>
                <span>🕒 ${formatDate(post.created_at)}</span>
              </div>
              <div class="post-content-container hidden border-t border-gray-100 dark:border-gray-800 mt-3 pt-3 transition-all duration-300">
                <p class="post-content-text text-gray-600 dark:text-gray-300 leading-relaxed whitespace-pre-line break-words text-sm"></p>
              </div>
            </article>
          `).join('');
        } else {
          boardLoading.classList.add('hidden');
          boardEmpty.classList.remove('hidden');
        }
      } catch {
        boardLoading.classList.add('hidden');
        boardEmpty.classList.remove('hidden');
      }
    }

    // Set Listeners
    if (blogContainer) {
      blogContainer.addEventListener('click', (e) => {
        const article = (e.target as HTMLElement).closest('article');
        if (article && article.dataset.slug) openBlogModal(article.dataset.slug);
      });
    }

    if (boardContainer) {
      boardContainer.addEventListener('click', (e) => {
        const article = (e.target as HTMLElement).closest('article');
        if (article && article.dataset.id) toggleBoardDetail(article.dataset.id, article);
      });
    }

    // Run
    loadBlog();
    loadBoard();
  });
</script>

<style>
  :root {
    --accent-gradient-strong: linear-gradient(
      45deg,
      #d648ff,
      #00d1b7,
      #d648ff
    );
  }

  .text-gradient {
    background-image: var(--accent-gradient-strong);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-size: 400%;
    background-position: 0%;
  }

  /* 마크다운 스타일 지정 */
  .markdown-body {
    font-size: 1.05rem;
    line-height: 1.75;
  }
  .markdown-body :global(h1) { font-size: 1.7em; font-weight: 800; margin-top: 1.6rem; margin-bottom: 0.6rem; border-bottom: 1px solid var(--brand-neutral); padding-bottom: 0.3rem; }
  .markdown-body :global(h2) { font-size: 1.4em; font-weight: 700; margin-top: 1.4rem; margin-bottom: 0.5rem; }
  .markdown-body :global(p) { margin-bottom: 1rem; color: #4b5563; }
  :global(.dark) .markdown-body :global(p) { color: #d1d5db; }
  .markdown-body :global(pre) { background: #f3f4f6; padding: 1rem; border-radius: 0.5rem; overflow-x: auto; margin-bottom: 1rem; }
  :global(.dark) .markdown-body :global(pre) { background: #1f2937; }
  .markdown-body :global(code) { font-family: monospace; background: #e5e7eb; padding: 0.1rem 0.3rem; border-radius: 0.25rem; }
  :global(.dark) .markdown-body :global(code) { background: #374151; }
</style>
